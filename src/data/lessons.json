  "units": [
    {
      "id": "u1-beginnings",
      "title": "Creation & Beginnings",
      "subtitle": "Unit 1 · Genesis 1–11",
      "skills": [
        {
          "id": "s1-creation",
          "title": "In the Beginning",
          "icon": "sun",
          "lessons": [
            {
              "id": "l1-1-read",
              "type": "read",
              "title": "Read Genesis 1:1–13",
              "ref": "Genesis 1:1-13",
              "reflectPrompt": "What does it mean that God called the light 'good' before there was anyone to see it? What does that say about how God works?"
            },
            {
              "id": "l1-2-quiz",
              "type": "quiz",
              "title": "Day-by-day quiz",
              "questions": [
                {
                  "kind": "mc",
                  "prompt": "On which day did God create light?",
                  "options": ["Day 1", "Day 2", "Day 3", "Day 4"],
                  "answerIndex": 0,
                  "explain": "Light comes on Day 1; the sun, moon, and stars not until Day 4 — a deliberate order."
                },
                {
                  "kind": "mc",
                  "prompt": "What did God create on the sixth day?",
                  "options": ["Sea creatures", "Plants", "Land animals and humanity", "Sun and moon"],
                  "answerIndex": 2,
                  "explain": "Land animals and then humanity — male and female in God's image."
                },
                {
                  "kind": "fill",
                  "prompt": "Complete: 'In the beginning God created the ____ and the earth.'",
                  "answer": "heaven"
                },
                {
                  "kind": "mc",
                  "prompt": "What did God do on the seventh day?",
                  "options": ["Created angels", "Rested", "Spoke to Adam", "Made a covenant"],
                  "answerIndex": 1,
                  "explain": "He rested and blessed the seventh day, setting the pattern of Sabbath."
                }
              ]
            },
            {
              "id": "l1-3-history",
              "type": "history",
              "title": "Ancient cosmology context",
              "cardId": "ane-cosmology",
              "checkQuestion": {
                "kind": "mc",
                "prompt": "What sets Genesis apart from other ancient creation accounts?",
                "options": [
                  "It is the oldest",
                  "It describes creation as a battle between gods",
                  "One God creates by word and calls it good",
                  "It includes a flood narrative"
                ],
                "answerIndex": 2,
                "explain": "Genesis depicts a single God speaking creation into being and pronouncing it good — a sharp contrast to violent creation myths of the region."
              }
            },
            {
              "id": "l1-4-memorize",
              "type": "memorize",
              "title": "Memorize Genesis 1:1",
              "ref": "Genesis 1:1",
              "text": "In the beginning God created the heaven and the earth."
            }
          ]
        },
        {
          "id": "s2-image",
          "title": "Made in His Image",
          "icon": "sparkles",
          "lessons": [
            {
              "id": "l2-1-read",
