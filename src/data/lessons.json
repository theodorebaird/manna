        {
          "id": "s3-fall",
          "title": "The Fall",
          "icon": "mountain",
          "lessons": [
            {
              "id": "l3-1-read",
              "type": "read",
              "title": "Read Genesis 3",
              "ref": "Genesis 3:1-15",
              "reflectPrompt": "Where does the serpent's deception begin — with the action, or with how Eve sees God? What's the pattern?"
            },
            {
              "id": "l3-2-quiz",
              "type": "quiz",
              "title": "The Fall quiz",
              "questions": [
                {
                  "kind": "mc",
                  "prompt": "What did the serpent say would happen if Eve ate the fruit?",
                  "options": ["She would die", "Her eyes would be opened and she'd be as gods", "She would become wise", "She would have to leave the garden"],
                  "answerIndex": 1
                },
                {
                  "kind": "mc",
                  "prompt": "Who is the 'seed' in Genesis 3:15 that will bruise the serpent's head?",
                  "options": ["Cain", "Abel", "A future descendant — traditionally read as the Messiah", "Adam himself"],
                  "answerIndex": 2,
                  "explain": "Genesis 3:15 is often called the protoevangelium — the first hint of the gospel."
                },
                {
                  "kind": "order",
                  "prompt": "Put these events in order:",
                  "items": [
                    "Serpent questions God's word",
                    "Eve eats the fruit and gives to Adam",
                    "Their eyes are opened and they hide",
                    "God pronounces judgment and the promise of a seed"
                  ]
                }
              ]
            }
          ]
        },
